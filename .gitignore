dist/
build/                    # Go 编译产物（二进制文件）
bin/                      # 二进制文件
*.exe
*.dll
*.so
*.dylib

# Go
*.test
*.out
go.work

# 日志和临时文件
*.log
*.tmp
*.pid
tmp/
temp/
logs/                     # 日志目录

# 上传文件（开发环境）
