# =============================================================================
# Contful 环境变量配置
# =============================================================================
#
# 使用方式:
#   cp .env.example .env
#   # 编辑 .env，填入实际的值
#   docker compose -f docker/docker-compose.yaml --env-file .env up -d
#
# 注意: .env 文件包含敏感信息，请勿提交到版本库
#
# =============================================================================

# ---- 数据库配置（PostgreSQL）----

# 数据库主机地址，Docker Compose 环境中使用服务名即可
DB_HOST=postgres

# 数据库端口，PostgreSQL 默认端口为 5432
DB_PORT=5432

# 数据库用户名，示例: postgres / contful_user
DB_USER=postgres

# 数据库密码，生产环境务必修改为强密码，示例: MyStr0ng!P@ss
DB_PASSWORD=changeme

# 数据库名称，示例: contful
DB_NAME=contful

# SSL 连接模式，可选值:
#   disable    — 不使用 SSL（本地开发/内网环境推荐）
#   require    — 必须使用 SSL，但不验证证书
#   verify-ca  — 使用 SSL 并验证 CA 证书
#   verify-full — 使用 SSL 并验证证书与主机名
DB_SSLMODE=disable

# ---- Redis / Valkey 配置 ----

# Redis/Valkey 主机地址，Docker Compose 环境中使用服务名即可
REDIS_HOST=valkey

# Redis/Valkey 端口，默认端口为 6379
REDIS_PORT=6379

# Redis/Valkey 密码，生产环境务必修改为强密码，示例: MyStr0ng!R3dis
REDIS_PASSWORD=changeme

# Redis 数据库编号，可选值: 0 ~ 15（共 16 个逻辑数据库）
REDIS_DB=0

# ---- 主密钥（AES-256-GCM 加密核心配置）----

# 用于 AES-256-GCM 加密的主密钥（32 字节十六进制字符串）
# 生成方式: openssl rand -hex 32
# 示例: a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0
# ⚠️ 密钥一旦设定请勿更改，否则已加密数据将无法解密
SECRET=changeme

# ---- 服务配置 ----

# HTTP 服务监听端口，默认 9080，示例: 9080 / 8080
# CONTFUL_SERVER_PORT=9080

# 服务运行模式，可选值:
#   release — 生产/发布模式（日志精简、性能优化）
#   debug   — 调试模式（日志详细、支持热重载）
# CONTFUL_SERVER_MODE=release

# Contful 运行形态，可选值:
#   console — 命令行/终端模式
#   server  — HTTP 服务模式
# CONTFUL_MODE=console

# ---- 自动初始化（默认 true，首次启动空库自动创建表+种子数据）----

# 是否在服务启动时自动执行数据库初始化（建表 + 种子数据）
#   true  — 首次启动时自动初始化空数据库
#   false — 跳过自动初始化，需手动执行迁移
CONTFUL_AUTO_INIT=true

# ---- 加密模式 ----

# 加密算法模式，可选值:
#   rsa — 国际算法（RSA + AES-256-GCM）
#   sm  — 国密算法（SM2 非对称 + SM3 哈希 + SM4 对称加密）
CRYPTO_MODE=rsa
