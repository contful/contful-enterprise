# =============================================================================
# Contful 统一配置文件
# =============================================================================
# 使用方式：
#   cp .env.example .env
#   修改 .env 中的配置项
#
# Docker 环境：
#   docker-compose --env-file .env up -d
# =============================================================================

# =============================================================================
# Admin API 配置（Console 管理后台）
# 容器内监听 9080，由 nginx 反向代理到 :80
# =============================================================================
ADMIN_SERVER_PORT=9080

# 安全配置（统一密钥，用于 JWT 签名和数据加密）
SECRET=your-master-secret-change-in-production
SECRET_ALGORITHM=aes-256-gcm  # AES-256-GCM（基于 Go 标准库）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Open API 配置（对外服务）
# 容器内监听 8080，宿主机映射 8080
# Open API 使用 API Token 认证，无需 JWT 配置
# =============================================================================
API_SERVER_PORT=8080

# =============================================================================
# 数据库配置（Admin 和 Open API 共享）
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=contful
DB_SSL_MODE=disable

# =============================================================================
# Redis 配置（Admin 和 Open API 共享）
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# 文件存储配置
# =============================================================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
