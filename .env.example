# =============================================================================
# Contful 环境变量配置
# =============================================================================
#
# 使用方式:
#   cp .env.example .env
#   # 编辑 .env，填入实际的值
#   docker compose -f docker/docker-compose.yaml --env-file .env up -d
#
# 注意: .env 文件包含敏感信息，请勿提交到版本库
#
# =============================================================================

# ---- 数据库配置（PostgreSQL）----
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=contful
DB_SSLMODE=disable

# ---- Redis / Valkey 配置 ----
REDIS_HOST=valkey
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# ---- 主密钥（AES-256-GCM 加密核心配置）----
SECRET=changeme

# ---- 服务配置 ----
# CONTFUL_SERVER_PORT=9080
# CONTFUL_SERVER_MODE=release
# CONTFUL_MODE=console

# ---- 自动初始化（默认 true，首次启动空库自动创建表+种子数据）----
CONTFUL_AUTO_INIT=true

# ---- 加密模式：rsa（国际算法）/ sm（国密 SM2+SM3+SM4）----
CRYPTO_MODE=rsa
