# =============================================================================
# Contful 环境配置
# =============================================================================
# 复制为 .env 后填入实际值:  cp .env.example .env
# =============================================================================

# ---- 数据库（PostgreSQL 18）----
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=contful
DB_PASSWORD=
DB_NAME=contful
DB_SSL_MODE=disable

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
JWT_SECRET=

# ---- 存储 ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
