# =============================================================================
# Contful Docker 环境变量配置
# 复制为 .env 并填入实际值
# =============================================================================

# ---- 数据库（PostgreSQL 18）----
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=contful
DB_PASSWORD=your-db-password-here
DB_NAME=contful
DB_SSL_MODE=disable

# ---- Redis ----
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT 密钥（必填，建议 32+ 字符随机字符串）----
JWT_SECRET=your-super-secret-key-at-least-32-characters

# ---- Open API Rate Limit（可选）----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=60
