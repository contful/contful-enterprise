# Contful Docker 环境配置
# ⚠️ 生产环境必须修改所有密码和密钥！

# 数据库配置
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=contful
# ⚠️ 必须修改
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_NAME=contful

# Redis 配置
REDIS_HOST=host.docker.internal
REDIS_PORT=6379

# Admin API
# ⚠️ 必须修改（建议使用 openssl rand -base64 32 生成）
ADMIN_JWT_SECRET=CHANGE_ME_IN_PRODUCTION
ADMIN_JWT_EXPIRE_MINUTES=15
ADMIN_REFRESH_TOKEN_EXPIRE_DAYS=7

# Open API
# ⚠️ 必须修改（建议使用 openssl rand -base64 32 生成）
OPEN_JWT_SECRET=CHANGE_ME_IN_PRODUCTION
OPEN_JWT_EXPIRE_MINUTES=60
OPEN_REFRESH_TOKEN_EXPIRE_DAYS=30

# 端口映射（可选）
ADMIN_PORT=8080
OPEN_PORT=8081
