# Contful Open API 配置
# 敏感信息（密码、密钥）通过 .env 文件配置
# 环境变量可覆盖配置，格式：CONTFUL_OPEN_xxx

# 服务配置
server:
  port: "8080"
  mode: release
  read_timeout: 60
  write_timeout: 60
  shutdown_timeout: 30

# 数据库（敏感信息在 .env 中配置）
database:
  host: localhost
  port: 5432
  user: postgres
  password: ""           # 从 .env 读取
  name: contful
  ssl_mode: disable
  max_open_conns: 100
  max_idle_conns: 10
  conn_max_lifetime: 3600

# Redis（密码在 .env 中配置）
redis:
  host: localhost
  port: 6379
  password: ""           # 从 .env 读取
  db: 0
  pool_size: 100

# 文件存储
storage:
  upload_dir: ./uploads
  max_upload_size_mb: 10

# 日志配置
logging:
  level: info
  format: json
  output: stdout

# 限流配置
rate_limit:
  enabled: true
  requests_per_minute: 100
