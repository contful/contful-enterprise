# =============================================================================
# Contful 配置文件
# =============================================================================
#
# 使用说明:
#   1. 复制此文件为 config.yml
#   2. 修改配置项（删除注释或保持 # 开头为注释）
#   3. 配置会自动加载
#
# 配置优先级（从高到低）:
#   1. 环境变量 (CONTFUL_xxx)
#   2. config.yml 中的值
#   3. 此文件中的默认值
#
# =============================================================================

# 服务配置
server:
  port: 8080
  mode: release
  read_timeout: 60
  write_timeout: 60
  shutdown_timeout: 30

# 数据库配置
database:
  type: postgres          # postgres（默认）/ dm（达梦 DM8）
  host: postgres
  port: 5432
  user: postgres
  password: your_db_password
  name: contful
  ssl_mode: disable
  max_open_conns: 100
  max_idle_conns: 10
  conn_max_lifetime: 3600

# Redis 配置
redis:
  host: redis
  port: 6379
  password: ""
  db: 0
  pool_size: 100

# 安全配置（生成密钥: openssl rand -hex 32）
security:
  secret: your_secret_key_here
  algorithm: aes-256-gcm  # aes-256-gcm（默认）/ sm4-gcm（国密）

# JWT 配置（自动从 security.secret 派生，如需单独配置可取消注释）
# jwt:
#   secret: your_jwt_secret_here
#   access_token_expire_minutes: 15
#   refresh_token_expire_days: 7

# 文件存储配置
storage:
  driver: local           # local / s3 / oss / cos / obs
  upload_dir: ./uploads
  max_upload_size_mb: 10
  base_url: /assets
  allowed_extensions:
    - .jpg
    - .jpeg
    - .png
    - .gif
    - .webp
    - .pdf
    - .doc
    - .docx
    - .xls
    - .xlsx

  # 云存储凭证（切换到 s3/oss/cos/obs 驱动时取消注释并填入）
  # oss:
  #   bucket: your-bucket
  #   endpoint: oss-cn-hangzhou.aliyuncs.com
  #   access_key: your-access-key
  #   secret_key: your-secret-key
  # s3:
  #   bucket: your-bucket
  #   endpoint: s3.amazonaws.com
  #   region: us-east-1
  # cos:
  #   bucket: your-bucket-1250000000
  #   region: ap-guangzhou
  # obs:
  #   bucket: your-bucket
  #   endpoint: obs.myhwclouds.com

# CORS 配置
cors:
  allowed_origins:
    - http://localhost:5173
    - http://localhost:3000
  allowed_methods:
    - GET
    - POST
    - PUT
    - DELETE
    - OPTIONS
  allowed_headers:
    - "*"
  allow_credentials: true
  max_age: 86400

# 日志配置
logging:
  level: info             # debug / info / warn / error
  format: json            # json / text
  output: stdout          # stdout / stderr / 文件路径

# 审计日志
audit:
  enabled: true
  log_all_requests: false

# 多站点配置
multi_site:
  enabled: true
  default_site_id: ""

# 特性开关
features:
  version_history: true
  api_tokens: true
  media_library: true
