# =============================================================================
# Contful 环境变量配置
# =============================================================================
#
# 使用方式:
#   cp .env.example .env
#   # 编辑 .env，填入实际的值
#   docker-compose --env-file .env up -d
#
# 注意: .env 文件包含敏感信息，请勿提交到版本库
#
# =============================================================================

# ---- 数据库配置（PostgreSQL）----
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password-change-me
DB_NAME=contful
DB_SSL_MODE=disable
DB_TYPE=postgres

# ---- Redis 配置 ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-change-me
REDIS_DB=0

# ---- 安全配置（必需）----
# 生成命令: openssl rand -hex 32
SECRET=your-64-char-hex-secret-change-me-use-openssl-rand-hex-32
SECRET_ALGORITHM=aes-256-gcm

# ---- 服务配置（可选）----
CONTFUL_SERVER_PORT=9080
CONTFUL_SERVER_MODE=release
CONTFUL_MODE=console

# ---- 日志配置（可选）----
LOG_LEVEL=info

# ---- 存储配置（可选）----
STORAGE_DRIVER=local
STORAGE_UPLOAD_DIR=./uploads
STORAGE_MAX_UPLOAD_SIZE_MB=10
STORAGE_BASE_URL=/uploads
