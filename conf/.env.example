# =============================================================================
# Contful 开发环境配置
# =============================================================================
#
# 使用方式:
#   cp .env.example .env
#
# 注意: .env 文件包含敏感信息，请勿提交到版本库
#
# =============================================================================

# ---- Admin API 配置 ----
SERVER_PORT=9080

# 安全配置（统一密钥，用于 JWT 签名和数据加密）
SECRET=your-master-secret-change-in-production
SECRET_ALGORITHM=aes-256-gcm

# JWT 配置（secret 留空，从 SECRET 自动派生）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- 数据库配置（PostgreSQL）----
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=contful
DB_SSL_MODE=disable

# ---- Redis 配置 ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ---- 存储配置 ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10