# =============================================================================
# Contful 环境变量配置模板
# 复制为 .env 使用：cp .env.example .env
# 
# 配置优先级：
#   1. .env 环境变量（最高）
#   2. conf/console.yaml 配置文件
#   3. 代码内置默认值
# =============================================================================

# ── 数据库 ──────────────────────────────────────────────────────────────────
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=CHANGE_ME
# DB_NAME=contful
# DB_SSL_MODE=disable

# ── Redis ───────────────────────────────────────────────────────────────────
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ── JWT ─────────────────────────────────────────────────────────────────────
# 若不设置则从 security.secret 自动派生
# CONTFUL_JWT_SECRET=

# ── 安全配置 ────────────────────────────────────────────────────────────────
# 主密钥（用于加密存储）：openssl rand -hex 32
# CONTFUL_SECURITY_SECRET=ef3594a7274376527e4a31fc99341a27e372e7e7f3295c796684ef6a0149afea

# RSA 密钥对（用于前端登录密码加密传输）
# 生成命令：openssl genrsa -out private.pem 2048；openssl rsa -in private.pem -pubout -out public.pem
# 不设置则使用 conf/console.yaml 中的默认值
# CONTFUL_SECURITY_RSA_PUBKEY="-----BEGIN PUBLIC KEY-----
# MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
# -----END PUBLIC KEY-----"
# CONTFUL_SECURITY_RSA_PRIVKEY="-----BEGIN RSA PRIVATE KEY-----
# MIIEpAIBAAKCAQEA...
# -----END RSA PRIVATE KEY-----"

# ── 存储 ────────────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local
# STORAGE_UPLOAD_DIR=./uploads
# STORAGE_MAX_UPLOAD_SIZE_MB=10
