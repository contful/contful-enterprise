# =============================================================================
# Contful 环境变量配置模板
# 复制为 .env 使用：cp .env.example .env
# 
# 配置优先级：
#   1. .env 环境变量（最高）
#   2. conf/console.yaml 配置文件
#   3. 代码内置默认值
# =============================================================================

# ── 数据库 ──────────────────────────────────────────────────────────────────
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=CHANGE_ME
# DB_NAME=contful
# DB_SSL_MODE=disable

# ── Redis ───────────────────────────────────────────────────────────────────
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ── JWT ─────────────────────────────────────────────────────────────────────
# 若不设置则从 security.secret 自动派生
# CONTFUL_JWT_SECRET=

# ── 安全配置 ────────────────────────────────────────────────────────────────
# 主密钥（用于加密存储）：openssl rand -hex 32
# CONTFUL_SECURITY_SECRET=ef3594a7274376527e4a31fc99341a27e372e7e7f3295c796684ef6a0149afea

# RSA 密钥对（用于前端登录密码加密传输）
# 文件存放在 conf/ 目录，默认使用 rsa_public.pem / rsa_private.pem
# 可通过环境变量覆盖路径：CONTFUL_SECURITY_RSA_PUBKEY_PATH / CONTFUL_SECURITY_RSA_PRIVKEY_PATH
# 生成命令：openssl genrsa -out rsa_private.pem 2048 && openssl rsa -in rsa_private.pem -pubout -out rsa_public.pem

# ── 存储 ────────────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local
# STORAGE_UPLOAD_DIR=./uploads
# STORAGE_MAX_UPLOAD_SIZE_MB=10
