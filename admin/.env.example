# Admin API 配置
SERVER_PORT=9080

# 安全配置（统一密钥）
# SECRET: 主密钥，用于 JWT 签名和数据加密
#   - 支持 64 字符 hex（纯 0-9a-f）：openssl rand -hex 32
#   - 支持任意长度字符串（会自动派生 32 字节密钥）
# ⚠️ 重要：此密钥用于加密存储敏感数据，变更前请确保无遗留加密数据
SECRET=0a8c6ca988b54e63c95fa34588f3bfcad1e08deca16a66001a8f8ef0977b1d8d
# SECRET_ALGORITHM: 加密算法（可选，默认 aes-256-gcm）
#   - aes-256-gcm: AES-256-GCM（推荐）
#   - sm4-gcm: 国密 SM4-GCM（需国密支持）
SECRET_ALGORITHM=aes-256-gcm

# JWT 配置（可省略，会从 SECRET 自动派生）
# JWT_SECRET: JWT 签名密钥（留空则从 SECRET 派生）
# 生成方式: openssl rand -base64 32 | tr -d '=\n' | tr '/+' '_-'
# JWT_SECRET=AYSr6OkSoo0Pnj-oOznbBKqX6XEdRoPzR72HrUW2blw
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=contful
DB_PASSWORD=your-db-password
DB_NAME=contful
DB_SSL_MODE=disable

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 存储配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
