# Admin API 配置
SERVER_PORT=9080

# JWT 配置
ADMIN_JWT_SECRET=your-secret-key-change-in-production
ADMIN_JWT_EXPIRE_MINUTES=15
ADMIN_REFRESH_TOKEN_EXPIRE_DAYS=7

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=contful
DB_PASSWORD=your-db-password
DB_NAME=contful
DB_SSL_MODE=disable

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 存储配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
