# Admin API 配置
SERVER_PORT=9080

# JWT 配置
# JWT_SECRET: JWT 签名密钥
# 生成方式: openssl rand -base64 32 | tr -d '=\n' | tr '/+' '_-'
JWT_SECRET=AYSr6OkSoo0Pnj-oOznbBKqX6XEdRoPzR72HrUW2blw
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=contful
DB_PASSWORD=your-db-password
DB_NAME=contful
DB_SSL_MODE=disable

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 存储配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# 安全配置
# API_TOKEN_KEY: API Token 加密密钥（AES-256-GCM）
#   - 支持任意长度字符串（会自动派生 32 字节密钥）
#   - 推荐使用 64 字符 hex（纯 0-9a-f）：openssl rand -hex 32
# ⚠️ 警告：变更此密钥将导致所有现有 API Token 无法解密！
#    如需变更，请先导出所有 Token，修改配置后重新生成 Token。
API_TOKEN_KEY=0a8c6ca988b54e63c95fa34588f3bfcad1e08deca16a66001a8f8ef0977b1d8d
