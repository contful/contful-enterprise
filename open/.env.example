# Open API 配置
SERVER_PORT=8081

# JWT 配置
OPEN_JWT_SECRET=your-secret-key-change-in-production
OPEN_JWT_EXPIRE_MINUTES=60
OPEN_REFRESH_TOKEN_EXPIRE_DAYS=30

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=contful
DB_PASSWORD=your-db-password
DB_NAME=contful
DB_SSL_MODE=disable

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 存储配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
